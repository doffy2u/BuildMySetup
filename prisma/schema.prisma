datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum PlanTier {
  FREE
  PRO
  ENTERPRISE
}

enum BuildStatus {
  DRAFT
  SAVED
  PUBLIC
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  name          String?
  avatarUrl     String?
  plan          PlanTier       @default(FREE)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  builds        Build[]
  favorites     Favorite[]
  subscriptions Subscription[]
  payments      Payment[]
  reports       Report[]

  @@index([email])
}

model Subscription {
  id                   String    @id @default(uuid())
  userId               String
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  stripeSubscriptionId String    @unique
  stripePriceId        String
  active               Boolean   @default(true)
  currentPeriodEnd     DateTime
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([userId])
}

model Payment {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  stripeId      String   @unique
  amount        Int
  currency      String   @default("usd")
  status        String
  createdAt     DateTime @default(now())

  @@index([userId])
}

model Component {
  id            String       @id @default(uuid())
  category      String
  brand         String
  modelName     String
  specs         Json
  price         Decimal      @db.Decimal(10, 2)
  watts         Int
  socket        String?
  dimensions    Json?
  inStock       Boolean      @default(true)
  affiliateUrl  String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  buildParts    BuildPart[]

  @@index([category, brand])
}

model Build {
  id            String       @id @default(uuid())
  userId        String
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  title         String
  description   String?
  budget        Int?
  purpose       String?
  country       String?
  status        BuildStatus  @default(DRAFT)
  totalWatts    Int          @default(0)
  totalPrice    Decimal      @default(0.00) @db.Decimal(10, 2)
  isCompatible  Boolean      @default(true)
  warnings      String[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  parts         BuildPart[]
  favorites     Favorite[]

  @@index([userId])
  @@index([status])
}

model BuildPart {
  id          String    @id @default(uuid())
  buildId     String
  build       Build     @relation(fields: [buildId], references: [id], onDelete: Cascade)
  componentId String
  component   Component @relation(fields: [componentId], references: [id], onDelete: Restrict)
  quantity    Int       @default(1)

  @@unique([buildId, componentId])
}

model Favorite {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  buildId   String
  build     Build    @relation(fields: [buildId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, buildId])
}

model BlogPost {
  id        String   @id @default(uuid())
  slug      String   @unique
  title     String
  content   String   @db.Text
  excerpt   String?
  published Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
}

model Report {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  type      String
  data      Json
  createdAt DateTime @default(now())

  @@index([userId])
}
